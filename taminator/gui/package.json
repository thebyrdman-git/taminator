{
  "name": "taminator-gui",
  "version": "2.0.0",
  "description": "Taminator RFE Tool - GUI Application",
  "homepage": "https://gitlab.cee.redhat.com/jbyrd/taminator",
  "repository": {
    "type": "git",
    "url": "https://gitlab.cee.redhat.com/jbyrd/taminator.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:linux:appimage": "electron-builder --linux AppImage",
    "build:linux:arm64": "electron-builder --linux --arm64",
    "build:linux:arm64:appimage": "electron-builder --linux --arm64 -c linux.target=AppImage",
    "build:linux:rpm": "electron-builder --linux rpm",
    "build:win": "electron-builder --win",
    "dev": "electron . --dev"
  },
  "author": "Jimmy Byrd",
  "license": "ISC",
  "dependencies": {
    "@patternfly/react-core": "^5.4.2",
    "@patternfly/react-icons": "^5.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.redhat.taminator",
    "productName": "Taminator",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "index.html",
      "public/**/*",
      "package.json",
      "../gui_auth_check.py",
      "../src/**/*"
    ],
    "asarUnpack": [
      "../gui_auth_check.py",
      "../src/**/*"
    ],
    "extraResources": [
      { "from": "../web", "to": "web" },
      { "from": "../web_server.py", "to": "." },
      { "from": "../tam-rfe", "to": "." }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "../web/taminator_logo.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "type": "distribution"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Development",
      "icon": "../web/taminator_logo.png",
      "maintainer": "jbyrd@redhat.com",
      "vendor": "Red Hat",
      "synopsis": "RFE and Bug Report Generator",
      "description": "RFE/Bug tracking tool for Red Hat TAMs"
    }
  }
}
