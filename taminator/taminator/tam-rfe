  On first use, you'll be prompted to configure required tokens.

Documentation:
  tam-rfe docs            Show full user guide in terminal
  https://gitlab.cee.redhat.com/jbyrd/taminator
"""
    console.print(help_text, style="cyan")


def show_docs():
    """Print full user documentation. Prefer bundled markdown; fall back to short summary + URL."""
    # Paths relative to tam-rfe location: _root is taminator app dir; repo root is _root/..
    repo_root = os.path.join(_root, '..')
    candidates = [
        os.path.join(repo_root, 'README.md'),
        os.path.join(_root, '..', 'README.md'),
        os.path.join(_root, 'README.md'),
        os.path.join(repo_root, 'GETTING-STARTED.md'),
        os.path.join(_root, '..', 'GETTING-STARTED.md'),
        os.path.join(_root, 'GETTING-STARTED.md'),
    ]
    seen = set()
    parts = []
    for path in candidates:
        norm = os.path.normpath(path)
        if norm in seen or not os.path.isfile(path):
            continue
        seen.add(norm)
        try:
            with open(path, 'r', encoding='utf-8', errors='replace') as f:
                parts.append(f.read())
        except OSError:
            continue
    if parts:
        text = '\n\n---\n\n'.join(parts)
        # Use pager if stdout is a TTY and content is long
        if sys.stdout.isatty() and len(text) > 4000:
            import subprocess
            try:
                p = subprocess.Popen(
                    ['less', '-R', '-'],
                    stdin=subprocess.PIPE,
                    text=True,
                )
                p.communicate(input=text)
                return
            except (OSError, FileNotFoundError):
                pass
        console.print(text, style="dim")
    else:
        console.print("\nFull documentation is available in the repository and in the in-app User Guide.", style="cyan")
        console.print("  Repository: https://gitlab.cee.redhat.com/jbyrd/taminator\n", style="dim")
        console.print("Run from the repo (e.g. ~/taminator/taminator) so that tam-rfe docs can find README.md and GETTING-STARTED.md.\n", style="yellow")


if __name__ == '__main__':
    main()

